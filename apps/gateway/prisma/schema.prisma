// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique @db.VarChar(64)
  password  String   @db.VarChar(255)
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(128)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("create_time")
  updatedAt DateTime @updatedAt @map("update_time")

  roles    UserRole[]
  projects Project[]
  llms     Llm[]

  @@map("user")
}

model Role {
  id          Int      @id @default(autoincrement())
  roleCode    String   @unique @map("role_code") @db.VarChar(64)
  roleName    String   @map("role_name") @db.VarChar(64)
  description String?  @db.VarChar(255)
  status      Int      @default(1) @db.SmallInt // 0-禁用，1-启用
  createdAt   DateTime @default(now()) @map("create_time")
  updatedAt   DateTime @updatedAt @map("update_time")

  users UserRole[]

  @@map("role")
}

model UserRole {
  userId    String   @map("user_id")
  roleId    Int      @map("role_id")
  createdAt DateTime @default(now()) @map("create_time")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_role")
}

// 认证类型枚举
enum AuthType {
  NONE
  API_KEY
  DYNAMIC_TOKEN
}

model Project {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(128)
  description String?  @db.Text
  authType    AuthType @default(NONE) @map("auth_type")
  // 核心：将认证所需的所有敏感信息序列化为 JSON 后进行 AES-256-GCM 强加密。
  // - API_KEY 存储: { "key": "sk-xxx", "position": "header", "keyName": "Authorization" }
  // - DYNAMIC_TOKEN 存储: { "secret": "xxx", "tokenUrl": "https://...", "tokenPath": "data.token" }
  authConfig  String?  @map("auth_config") @db.Text 
  
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now()) @map("create_time")
  updatedAt   DateTime @updatedAt @map("update_time")

  agents      Agent[]

  @@map("project")
}

model Llm {
  id        String   @id @default(uuid())
  provider  String   @db.VarChar(64) // 供应商，如 openai, anthropic, deepseek
  name      String   @db.VarChar(128) // 模型名称，如 GPT-4, DeepSeek-V3
  baseUrl   String?  @map("base_url") @db.VarChar(255) // 自定义代理地址
  apiKey    String   @map("api_key") @db.Text // 必须使用 AES-256-GCM 加密存储，密文较长故用 Text
  isPublic  Boolean  @default(false) @map("is_public") // 是否为公共模型（仅超级管理员可设为 true）

  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("create_time")
  updatedAt DateTime @updatedAt @map("update_time")

  agents    Agent[]

  @@map("llm")
}

model Agent {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(128)
  description String?  @db.Text
  prompt      String?  @db.Text // 系统提示词
  llmParams   Json?    @map("llm_params") // 大模型参数配置
  isActive    Boolean  @default(true) @map("is_active") // 智能体状态
  
  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  llmId       String?  @map("llm_id")
  llm         Llm?     @relation(fields: [llmId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now()) @map("create_time")
  updatedAt   DateTime @updatedAt @map("update_time")

  @@map("agent")
}


